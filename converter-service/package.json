{
  "name": "bim-fragments-converter-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IFC to Fragments conversion and validation service scripts.",
  "scripts": {
    "convert": "node src/convert-ifc-to-fragments.js",
    "convert:full": "node src/convert-ifc-to-fragments.js --full-properties",
    "convert:8g": "node --max-old-space-size=8192 src/convert-ifc-to-fragments.js",
    "convert:full:8g": "node --max-old-space-size=8192 src/convert-ifc-to-fragments.js --full-properties",
    "convert:16g": "node --max-old-space-size=16384 src/convert-ifc-to-fragments.js",
    "serve": "node server/api-server.js",
    "validate:t003-t004": "node src/validate-t003-t004.js",
    "validate:t003-t004:8g": "node --max-old-space-size=8192 src/validate-t003-t004.js",
    "validate:t003-t004:16g": "node --max-old-space-size=16384 src/validate-t003-t004.js"
  },
  "dependencies": {
    "@thatopen/fragments": "3.4.5",
    "web-ifc": "0.0.77"
  }
}
